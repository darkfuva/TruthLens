{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=truthlens;Username=somename;Password=somepassword"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "EmbeddingModel": "nomic-embed-text",
    "ExtractionModel": "llama3.2:3b",
    "TimeoutSeconds": 60
  },
  "WorkerJobs": {
    "Ingestion": {
      "Enabled": true,
      "RunOnStart": true,
      "IntervalSeconds": 45,
      "MaxIterations": 20,
      "EmbeddingBatchSize": 32,
      "ClusteringBatchSize": 64,
      "ClusteringThreshold": 0.82
    },
    "Discovery": {
      "Enabled": true,
      "RunOnStart": true,
      "IntervalSeconds": 120,
      "MaxEvents": 20,
      "MinFeedsPerPost": 5,
      "AutoPromoteEnabled": false,
      "AutoPromoteMinConfidence": 0.65,
      "AutoPromoteMinSamplePostCount": 2,
      "AutoPromoteMaxCount": 25,
      "PostPromotionMaxCatchupIterations": 5
    },
    "Scoring": {
      "Enabled": true,
      "RunOnStart": true,
      "IntervalSeconds": 600,
      "MaxSources": 250,
      "MaxRecommended": 250,
      "MaxEvents": 200,
      "LookbackDays": 30
    },
    "Summarization": {
      "Enabled": true,
      "RunOnStart": true,
      "IntervalSeconds": 300,
      "BatchSize": 10,
      "MaxIterations": 20
    },
    "Backfill": {
      "Enabled": true,
      "RunOnStart": true,
      "IntervalSeconds": 3600,
      "LookbackDays": 30,
      "BatchSize": 300
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  }
}
